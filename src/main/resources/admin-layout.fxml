<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="768.0" prefWidth="1366.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.AdminController">

    <!-- THANH MENU BÊN TRÁI (SIDEBAR) -->
    <left>
        <VBox prefWidth="280.0" style="-fx-background-color: linear-gradient(to bottom, #2c3e50, #1a252f);">
            <VBox alignment="CENTER" spacing="5" style="-fx-padding: 25 20 20 20; -fx-border-color: transparent transparent rgba(255,255,255,0.1) transparent; -fx-border-width: 0 0 1 0;">
                <Label text="⚙️ ADMIN" style="-fx-font-size: 28px; -fx-text-fill: #f39c12; -fx-font-weight: bold;"/>
                <Label text="Hệ thống quản trị nội bộ" style="-fx-font-size: 12px; -fx-text-fill: #bdc3c7;"/>
            </VBox>

            <VBox spacing="10" style="-fx-padding: 20 15 0 15;">
                <Button text="📊 Thống kê Doanh thu" onAction="#moTrangThongKe" styleClass="admin-btn" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
                <Button text="📚 Quản lý Sách" onAction="#moTrangQuanLySach" styleClass="admin-btn" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
                <Button text="📦 Quản lý Đơn hàng" onAction="#moTrangDonHang" styleClass="admin-btn" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
                <Button text="🎟️ Mã giảm giá" onAction="#moTrangMaGiamGia" styleClass="admin-btn" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
                <Button text="👥 Nhà phân phối" onAction="#moTrangNhaCungCap" styleClass="admin-btn" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <VBox style="-fx-padding: 20 15 30 15;">
                <Button text="🚪 Đăng xuất hệ thống" onAction="#dangXuat" style="-fx-background-color: rgba(231, 76, 60, 0.2); -fx-text-fill: #e74c3c; -fx-border-color: rgba(231, 76, 60, 0.5); -fx-border-radius: 8;" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
            </VBox>
        </VBox>
    </left>

    <!-- KHU VỰC NỘI DUNG BÊN PHẢI SẼ THAY ĐỔI -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #f4f7f6; -fx-padding: 30;"/>
    </center>

</BorderPane>