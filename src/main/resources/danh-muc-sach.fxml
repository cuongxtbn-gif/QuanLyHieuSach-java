<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="danhMucRoot" prefHeight="750.0" prefWidth="1100.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.DanhMucSachController">

    <!-- HEADER & THANH TÌM KIẾM -->
    <top>
        <VBox spacing="10" styleClass="header">
        <padding><Insets top="15" right="30" bottom="15" left="30"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label text="🐵 BOOKSTORE" styleClass="logo" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f39c12;"/>
                <Region HBox.hgrow="ALWAYS" />

                <TextField fx:id="txtTimKiem" promptText="Tìm theo tên, tác giả, thể loại..." prefWidth="350" styleClass="search-input" />

                <HBox alignment="CENTER" spacing="15">
                    <Hyperlink onAction="#quayVeTrangChu" text="Trang chủ" styleClass="nav-link"/>
                    <Hyperlink text="Sách" styleClass="nav-link, active-link" style="-fx-text-fill: #f39c12;"/>
                    <Hyperlink text="Giỏ hàng" onAction="#moTrangGioHang" styleClass="nav-link"/>
                    <Hyperlink fx:id="linkAccount" onAction="#handleAccountAction" text="Tài khoản" styleClass="nav-link"/>
                </HBox>
            </HBox>

            <!-- THANH BỘ LỌC -->
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 10 0 0 0; -fx-border-color: #ecf0f1 transparent transparent transparent; -fx-border-width: 1 0 0 0;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Sắp xếp theo:" />
                    <ComboBox fx:id="cbSapXep" prefWidth="150" promptText="Mức độ phổ biến" />
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Thể loại:" />
                    <ComboBox fx:id="cbTheLoai" prefWidth="150" promptText="Tất cả" />
                </HBox>
            </HBox>
        </VBox>
    </top>

    <!-- DANH SÁCH CUỐN SÁCH -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox alignment="TOP_CENTER" spacing="20" style="-fx-padding: 30;">

                <!-- TilePane giúp các ô sách tự động rớt dòng khi hết chỗ ngang -->
                <TilePane fx:id="gridSach" hgap="25" vgap="25" alignment="TOP_CENTER" prefColumns="4">
                    <!-- Dữ liệu sách sẽ được Java tự động "bơm" vào đây sau -->
                    <Label text="Đang tải dữ liệu sách..." style="-fx-font-size: 16px; -fx-text-fill: #7f8c8d;"/>
                </TilePane>

                <!-- PHÂN TRANG -->
                <HBox alignment="CENTER" spacing="10" style="-fx-padding: 20 0 0 0;">
                    <Button fx:id="btnTrang1" onAction="#chuyenTrang1" text="1" styleClass="page-btn"/>
                    <Button fx:id="btnTrang2" onAction="#chuyenTrang2" text="2" styleClass="page-btn"/>
                    <Button fx:id="btnTrang3" onAction="#chuyenTrang3" text="3" styleClass="page-btn"/>
                    <Button fx:id="btnTrang4" onAction="#chuyenTrang4" text="4" styleClass="page-btn"/>
                    <Button onAction="#chuyenTrangTiep" text="Tiếp theo »" styleClass="page-btn"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>