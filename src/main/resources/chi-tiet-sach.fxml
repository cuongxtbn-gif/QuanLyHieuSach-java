<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="chiTietRoot" prefHeight="750.0" prefWidth="1100.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.ChiTietSachController">

    <top>
        <VBox spacing="10" styleClass="header">
            <padding><Insets top="15" right="30" bottom="15" left="30"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label text="🐵 BOOKSTORE" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f39c12;"/>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="15">
                    <Hyperlink onAction="#quayVeTrangChu" text="Trang chủ" styleClass="nav-link"/>
                    <Hyperlink onAction="#quayVeDanhSach" text="Sách" styleClass="nav-link"/>
                    <Hyperlink text="Giỏ hàng" styleClass="nav-link"/>
                    <Hyperlink fx:id="linkAccount" text="Tài khoản" styleClass="nav-link"/>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: white;">
            <VBox spacing="30" style="-fx-padding: 40;">
                <!-- Breadcrumb -->
                <HBox spacing="5">
                    <Hyperlink text="Sách" onAction="#quayVeDanhSach" style="-fx-text-fill: #7f8c8d;"/>
                    <Label text="&gt;" style="-fx-text-fill: #7f8c8d; -fx-padding: 4 0 0 0;"/>
                    <Label fx:id="lblDuongDan" text="Tên sách" style="-fx-text-fill: #f39c12; -fx-font-weight: bold; -fx-padding: 4 0 0 0;"/>
                </HBox>

                <!-- Vùng 1: Ảnh và Thông tin cơ bản -->
                <HBox spacing="40">
                    <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                        <ImageView fx:id="imgBiaSach" fitWidth="300" fitHeight="420" preserveRatio="true"/>
                    </VBox>

                    <VBox spacing="15" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblTenSach" text="Tên Sách" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" wrapText="true"/>
                        <HBox spacing="10">
                            <Label text="Tác giả:" style="-fx-text-fill: #7f8c8d;"/>
                            <Label fx:id="lblTacGia" text="Đang cập nhật" style="-fx-font-weight: bold;"/>
                        </HBox>
                        <Label fx:id="lblGiaBan" text="0 đ" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>

                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Label text="Số lượng:"/>
                            <TextField text="1" prefWidth="50" alignment="CENTER"/>
                            <Button text="Thêm vào giỏ hàng" style="-fx-border-color: #3498db; -fx-text-fill: #3498db; -fx-background-color: white;"/>
                            <Button text="Mua ngay" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- Vùng 2: BẢNG THÔNG TIN CHI TIẾT (Giống Web) -->
                <VBox spacing="15" style="-fx-background-color: #fafafa; -fx-padding: 20; -fx-background-radius: 5;">
                    <Label text="THÔNG TIN CHI TIẾT" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <GridPane hgap="20" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="150" prefWidth="150" />
                            <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>

                        <Label text="Nhà xuất bản:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="lblNhaXuatBan" text="Đang cập nhật" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-font-weight: bold;"/>

                        <Label text="Số trang:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="lblSoTrang" text="Đang cập nhật" GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-font-weight: bold;"/>

                        <Label text="Thể loại:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="lblTheLoaiDetail" text="Đang cập nhật" GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-font-weight: bold;"/>
                    </GridPane>
                </VBox>

                <!-- Vùng 3: MÔ TẢ SẢN PHẨM -->
                <VBox spacing="15">
                    <Label text="MÔ TẢ SẢN PHẨM" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label fx:id="lblMoTa" text="Nội dung mô tả đang được cập nhật..." wrapText="true" style="-fx-font-size: 14px; -fx-line-spacing: 5;"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>