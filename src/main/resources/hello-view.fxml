<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fx:controller="org.example.HelloController" fitToWidth="true" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <VBox spacing="20" styleClass="body-container">

        <!-- ================= HEADER ================= -->
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header">
            <padding>
                <Insets top="15" right="30" bottom="15" left="30"/>
            </padding>
            <Label text="🐵 BOOKSTORE" styleClass="logo"/>
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="txtTimKiem" promptText="Tìm theo tên, tác giả, thể loại... (Enter để mở danh mục)" styleClass="search-input" prefWidth="380" onAction="#timKiemVaMoDanhMuc"/>
            <HBox alignment="CENTER" spacing="15">
                <Hyperlink text="Trang chủ" styleClass="nav-link"/>
                <Hyperlink text="Sách" onAction="#moTrangDanhSachSach" styleClass="nav-link"/>
                <Hyperlink text="Giỏ hàng" onAction="#moTrangGioHang" styleClass="nav-link"/>
                <Hyperlink fx:id="linkAccount" text="Đăng nhập" styleClass="nav-link"/>
                <Hyperlink text="Đăng xuất" onAction="#handleCustomerLogout" styleClass="nav-link"/>
            </HBox>
        </HBox>

        <!-- ================= HERO SECTION ================= -->
        <VBox alignment="CENTER" spacing="15" styleClass="hero-banner">
            <padding>
                <Insets top="50" right="20" bottom="50" left="20"/>
            </padding>
            <Label text="Khơi nguồn tri thức" styleClass="hero-title"/>
            <Label text="Hơn 10.000 đầu sách ngoại văn, quốc ngữ và giáo trình mới nhất từ các nhà xuất bản hàng đầu." wrapText="true" styleClass="hero-description"/>
            <Button text="Khám phá ngay" onAction="#moTrangDanhSachSach" styleClass="btn-primary"/>
        </VBox>

        <!-- ================= SÁCH MỚI CẬP NHẬT (8 CUỐN) ================= -->
        <VBox spacing="15" styleClass="container">
            <padding>
                <Insets top="20" right="30" bottom="20" left="30"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Region prefWidth="5" prefHeight="30" style="-fx-background-color: #2563eb;"/>
                <Label text="Sách mới cập nhật" styleClass="section-title"/>
            </HBox>

            <FlowPane fx:id="flowSachMoi" hgap="30" vgap="30" alignment="CENTER"/>
        </VBox>

        <!-- ================= SÁCH ĐANG BÁN CHẠY (4 CUỐN) ================= -->
        <VBox spacing="15" styleClass="container">
            <padding>
                <Insets top="20" right="30" bottom="40" left="30"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Region prefWidth="5" prefHeight="30" style="-fx-background-color: #e74c3c; -fx-background-radius: 10;"/>
                <Label text="Sách đang bán chạy 🔥" styleClass="section-title"/>
            </HBox>

            <FlowPane fx:id="flowSachBanChay" hgap="30" vgap="30" alignment="CENTER"/>
        </VBox>

    </VBox>
</ScrollPane>