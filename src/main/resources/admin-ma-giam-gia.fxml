<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.MaGiamGiaController" stylesheets="@style.css">
    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

    <HBox spacing="15">
        <VBox styleClass="stat-card, green-border" HBox.hgrow="ALWAYS">
            <Label text="Voucher đang hoạt động"/>
            <Label fx:id="lblActiveCount" styleClass="stat-value" text="0"/>
        </VBox>
        <VBox styleClass="stat-card, blue-border" HBox.hgrow="ALWAYS">
            <Label text="Voucher đã hết hạn"/>
            <Label fx:id="lblExpiredCount" styleClass="stat-value" text="0"/>
        </VBox>
    </HBox>

    <VBox spacing="10" styleClass="table-container">
        <Label text="Thêm mã giảm giá mới" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
        <HBox spacing="10">
            <TextField fx:id="txtCode" promptText="Mã voucher (VD: SUMMER20)" HBox.hgrow="ALWAYS"/>
            <TextField fx:id="txtDiscountPercent" promptText="% giảm" prefWidth="90"/>
            <TextField fx:id="txtQuantity" promptText="Số lượng" prefWidth="110"/>
            <CheckBox fx:id="chkActive" text="Kích hoạt" selected="true"/>
        </HBox>
        <TextField fx:id="txtDescription" promptText="Mô tả voucher"/>
        <HBox spacing="10">
            <TextField fx:id="txtTargetUsers" promptText="Đối tượng áp dụng" HBox.hgrow="ALWAYS"/>
            <TextField fx:id="txtConditions" promptText="Điều kiện đơn hàng" HBox.hgrow="ALWAYS"/>
        </HBox>
        <Button text="Thêm voucher" onAction="#handleAddVoucher" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
    </VBox>

    <VBox spacing="8">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="Voucher đang hoạt động" styleClass="section-heading"/>
            <Button text="Chuyển sang hết hạn" onAction="#handleExpireSelected" style="-fx-background-color: #c0392b; -fx-text-fill: white;"/>
        </HBox>
        <TableView fx:id="tblActiveVouchers" prefHeight="230" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colActiveCode" text="Mã" prefWidth="140"/>
                <TableColumn fx:id="colActivePercent" text="% Giảm" prefWidth="90"/>
                <TableColumn fx:id="colActiveQty" text="Số lượng còn" prefWidth="120"/>
                <TableColumn fx:id="colActiveTarget" text="Đối tượng" prefWidth="180"/>
                <TableColumn fx:id="colActiveCondition" text="Điều kiện" prefWidth="360"/>
            </columns>
        </TableView>
    </VBox>

    <VBox spacing="8">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="Voucher đã hết hạn" styleClass="section-heading"/>
            <Button text="Kích hoạt lại" onAction="#handleReactivateSelected" style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
        </HBox>
        <TableView fx:id="tblExpiredVouchers" prefHeight="230" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colExpiredCode" text="Mã" prefWidth="140"/>
                <TableColumn fx:id="colExpiredPercent" text="% Giảm" prefWidth="90"/>
                <TableColumn fx:id="colExpiredQty" text="Số lượng còn" prefWidth="120"/>
                <TableColumn fx:id="colExpiredTarget" text="Đối tượng" prefWidth="180"/>
                <TableColumn fx:id="colExpiredCondition" text="Điều kiện" prefWidth="360"/>
            </columns>
        </TableView>
    </VBox>
</VBox>